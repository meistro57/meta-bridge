# OpenRouter API key (required)
OPENROUTER_API_KEY=sk-or-v1..

# Local Ollama base URL for ollama:<model> chat and ollama embeddings
OLLAMA_URL=http://localhost:11434

# Qdrant connection (optional)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Chat model override used by mb ingest and reflect.py
# mb default: google/gemma-4-31b-it
# reflect.py default: google/gemma-4-31b-it
# Other options to try:
#   deepseek/deepseek-r1
#   google/gemini-2.0-flash-exp:free
#   anthropic/claude-3.5-sonnet
#   openai/gpt-4o-mini
#   ollama:gemma4:latest
MB_MODEL=

# Embedding backend/model used by mb ingest and reflect.py
#   MB_EMBED_PROVIDER=openrouter  (default)
#   MB_EMBED_PROVIDER=ollama      (uses local Ollama /api/embeddings)
MB_EMBED_PROVIDER=openrouter
MB_EMBED_MODEL=openai/text-embedding-3-small

# Max chars used for source-level embedding text
MB_EMBED_MAX_CHARS=8000

# Optional regex override for section headers.
# If empty, built-in detection is used (CHAPTER <n>, SESSION <n>, PART <n|word>).
# Examples:
#   (?im)^\s*chapter\s+[a-z0-9-]+\b.*$
#   (?im)^\s*session\s+[a-z0-9-]+\b.*$
MB_HEADER_PATTERN=

# Limit chunks processed (useful for dry runs on a new source)
MB_MAX_CHUNKS=

# Output directory for JSON artifacts
MB_OUTPUT_DIR=./output

# Metadata overrides for the current source
MB_SOURCE_ID=
MB_TITLE=
MB_AUTHOR=
