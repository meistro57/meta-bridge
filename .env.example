# OpenRouter API key (required)
OPENROUTER_API_KEY=sk-or-v1..

# Extraction model override (optional; default: deepseek/deepseek-r1)
# Other options to try:
#   google/gemini-2.0-flash-exp:free
#   anthropic/claude-3.5-sonnet
#   openai/gpt-4o-mini
MB_MODEL=

# Limit chunks processed (useful for dry runs on a new source)
MB_MAX_CHUNKS=

# Output directory for JSON artifacts
MB_OUTPUT_DIR=./output

# Metadata overrides for the current source
MB_SOURCE_ID=
MB_TITLE=
MB_AUTHOR=
