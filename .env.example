# OpenRouter API key (required)
OPENROUTER_API_KEY=sk-or-v1..

# Local Ollama base URL for embeddings (optional)
OLLAMA_URL=http://localhost:11434

# Qdrant connection (optional)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Extraction model override (optional; default: deepseek/deepseek-r1)
# Other options to try:
#   google/gemini-2.0-flash-exp:free
#   anthropic/claude-3.5-sonnet
#   openai/gpt-4o-mini
#   ollama:gemma4
MB_MODEL=

# Max chars used for source-level embedding text (prevents Ollama context overflow)
MB_EMBED_MAX_CHARS=8000

# Optional regex for section headers (leave empty for unstructured input)
# Examples:
#   (?im)^\s*chapter\s+[a-z0-9-]+\b.*$
#   (?im)^\s*session\s+[a-z0-9-]+\b.*$
MB_HEADER_PATTERN=

# Limit chunks processed (useful for dry runs on a new source)
MB_MAX_CHUNKS=

# Output directory for JSON artifacts
MB_OUTPUT_DIR=./output

# Metadata overrides for the current source
MB_SOURCE_ID=
MB_TITLE=
MB_AUTHOR=
